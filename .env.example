# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Default image model (overridden by UI model picker)
# Popular options — see full list in src/lib/openrouter-models.ts
#
# Google (modalities: image+text, refs OK):
#   google/gemini-2.5-flash-image
#   google/gemini-3.1-flash-image-preview
#   google/gemini-3-pro-image-preview
#
# xAI Grok (modalities: image only):
#   x-ai/grok-imagine-image-quality
#
# OpenAI (modalities: image+text):
#   openai/gpt-5-image-mini
#   openai/gpt-5.4-image-2
#
# ByteDance (modalities: image only):
#   bytedance-seed/seedream-4.5
#
# Flux (modalities: image only):
#   black-forest-labs/flux.2-pro
#   black-forest-labs/flux.2-max
#
# Recraft / Riverflow (modalities: image only):
#   recraft/recraft-v4.1
#   sourceful/riverflow-v2-fast-preview
#
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image

# Max parallel image requests per generation batch (1–6)
OPENROUTER_CONCURRENCY=4

# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Auth → URL configuration (for Google OAuth):
#   Site URL: http://localhost:3000
#   Redirect URLs: http://localhost:3000/auth/callback
# Enable Google under Authentication → Providers (paste Google Cloud client id/secret)

# Run supabase/migrations/001_conversations_and_storage.sql in Supabase SQL Editor
# before using History + saved images.
